# ─── Backend CityFix — variables d'entorn ───
# Copia aquest fitxer a `.env` i omple els valors reals.
# El `.env` real NO es versiona (vegeu .gitignore).

# Port del servidor (opcional, per defecte 3000)
PORT=3000

# Cadena de connexió PostgreSQL (Supabase). OBLIGATÒRIA: el servidor no arrenca sense ella.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Secret per signar els JWT. OBLIGATÒRIA: el servidor no arrenca sense ella.
# Genera'n un de fiable amb:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Email de l'administrador root intocable (no es pot revocar). Per defecte admin.master@uab.cat
ROOT_ADMIN_EMAIL=admin.master@uab.cat

# Origen(s) permès(os) per CORS, separats per comes (p. ex. https://admin.cityfix.cat).
# Si es deixa buit, s'accepta qualsevol origen (còmode en dev, NO recomanat en producció).
FRONTEND_URL=http://localhost:5173

# ─── Supabase Storage (pujada d'imatges) ───
# Opcionals: si falten, la pujada d'imatges fallarà però la resta de l'app funciona.
SUPABASE_URL=https://<projecte>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=report-images

# ─── Auto-classificació IA (Google AI Studio / Gemini) ───
# Opcional: si falta, la classificació IA es desactiva amb un avís a la consola.
GEMINI_API_KEY=
