// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TypeImage {
  INITIAL
  RESOLUTION
  PROGRESS
}

enum Role {
  STUDENT
  ADMIN
  TECHNICAL
}
enum State {
  OPEN
  ASSIGNED
  IN_PROGRESS
  VALIDATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Category {
  LIGHTING
  URBAN_FURNITURE
  PAVEMENT
  CLEANING
  GREEN_AREAS
  SIGNAGE
  ACCESSIBILITY
  TECHNOLOGY
  OTHER
}

enum IncidentEvent {
  ASSIGN
  START
  REASSIGN
  RESOLVE
  CLOSE
  REJECT
}

model User {
  user_id         String    @id @default(uuid())
  email           String    @unique
  name            String
  surname         String
  password        String
  nickname        String    @unique
  role            Role
  active          Boolean   @default(true)
  points          Int       @default(0)
  avatarUrl       String?   // URL pública de la foto de perfil (Supabase Storage)

  // Camps específics per a tècnics (null per a STUDENT i ADMIN).
  // workCategory és el que utilitza l'algoritme de recomanació al panel d'admin.
  position        String?   // p. ex. "Electricista", "Jardiner"
  workCategory    Category? // àmbit principal del tècnic, lligat a Category de Report
  company         String?   // empresa contractista (Eulen, Ferrovial...)

  inviteId        String?   @unique
  invite          Invite?   @relation(fields: [inviteId], references: [id])

  reportsAssigned Report[]  @relation("AssignedReports")
  reportsCreated  Report[]  @relation("CreatedReports")
  comments        Comment[]
  imagesUploaded  Image[]   @relation("UploadedImages")
  pushTokens      PushToken[]
  notifications   Notification[]
  pointsTransactions PointsTransaction[]

  createdAt       DateTime  @default(now())
  lastModified    DateTime  @updatedAt

  @@map("users")
}

model Report{
  report_id       String     @id @default(uuid())
  title           String
  description     String

  state           State     @default(OPEN)
  priority        Priority  @default(MEDIUM)
  category        Category?

  latitude        Float
  longitude       Float
  location        Unsupported("geography(Point, 4326)")?

  images          Image[]
  comments        Comment[]
  notifications   Notification[]
  pointsTransaction PointsTransaction?

  createdById     String
  createdBy       User     @relation("CreatedReports", fields: [createdById], references: [user_id])

  assignedToId    String?
  assignedTo      User?    @relation("AssignedReports", fields: [assignedToId], references: [user_id])

  createdAt       DateTime  @default(now())
  lastModified    DateTime @updatedAt
  resolvedAt      DateTime?

  // Camps escrits pel sistema d'auto-classificació IA (Sprint 6).
  // `aiSummary` és un resum d'una línia per facilitar lectura ràpida al
  // dashboard. `aiClassifiedAt` serveix tant d'auditoria (sabem que va ser
  // l'IA i quan) com de senyal per al frontend (no executar de nou si ja
  // està classificat).
  aiSummary       String?
  aiClassifiedAt  DateTime?

  @@map("reports")
}

model Comment {
  id              String         @id @default(uuid())
  content         String
  transitionEvent IncidentEvent?

  createdAt       DateTime       @default(now())
  lastModified    DateTime       @updatedAt

  reportId        String
  report          Report         @relation(fields: [reportId], references: [report_id])

  authorId        String
  author          User           @relation(fields: [authorId], references: [user_id])

  @@map("comments")
}

model Image {
  id              String     @id @default(uuid())
  url             String
  type            TypeImage

  createdAt       DateTime   @default(now())
  lastModified    DateTime   @updatedAt

  reportId        String
  report          Report     @relation(fields: [reportId], references: [report_id])

  uploadedById    String?
  uploadedBy      User?      @relation("UploadedImages", fields: [uploadedById], references: [user_id])

  @@map("images")
}

enum InviteStatus {
  PENDING
  USED
  REVOKED
}

enum NotificationType {
  REPORT_ASSIGNED
  REPORT_REASSIGNED
  REPORT_UNASSIGNED
  REPORT_STATE_CHANGED
  POINTS_EARNED
}

// Token de push d'un dispositiu concret. Un usuari pot tenir-ne diversos
// (mòbil + tauleta). Quan Expo ens diu que un token està mort (DeviceNotRegistered)
// el marquem com a inactiu en lloc d'esborrar-lo, per tenir traça històrica.
model PushToken {
  id           String   @id @default(uuid())
  token        String   @unique
  platform     String   // 'ios' | 'android'
  active       Boolean  @default(true)

  userId       String
  user         User     @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@index([userId, active])
  @@map("push_tokens")
}

// Notificació persistida al sistema (campana / badge / historial in-app).
// El push és efímer: si el dispositiu està apagat es perd. Aquesta taula és
// la "veritat" del que ha passat i el que el client mòbil ha de mostrar.
model Notification {
  id           String           @id @default(uuid())
  type         NotificationType
  title        String
  body         String
  read         Boolean          @default(false)

  userId       String
  user         User             @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  reportId     String?
  report       Report?          @relation(fields: [reportId], references: [report_id], onDelete: SetNull)

  createdAt    DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model Invite {
  id              String       @id @default(uuid())
  email           String       @unique
  role            Role
  token           String       @unique
  status          InviteStatus @default(PENDING)
  expiresAt       DateTime     @default(dbgenerated("(now() + interval '7 days')"))
  createdAt       DateTime     @default(now())

  user            User?

  @@map("invites")
}

// Historial atòmic de cada premi de punts (Sprint Gamificació).
// Cada fila representa una concessió única vinculada a un report. La unicitat
// per reportId garanteix que mai es premiï dos cops el mateix report, encara
// que la transició CLOSE es disparés repetidament per un bug futur.
// El camp `priority` és un snapshot del moment de l'award, perquè si l'admin
// canvia la prioritat després el premi reflecteix el valor real aplicat.
model PointsTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  reportId    String   @unique
  report      Report   @relation(fields: [reportId], references: [report_id], onDelete: Cascade)

  amount      Int
  priority    Priority

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@map("points_transactions")
}

